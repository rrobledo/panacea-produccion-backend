# Pooled Postgres connection string (Vercel Postgres / Neon "-pooler" endpoint).
# postgresql+asyncpg://<user>:<password>@<host>/<db>?ssl=require
DATABASE_URL=

# Comma-separated list of accepted X-API-Key values for mutating requests.
API_KEYS=

# Secret required (in addition to an API key) to trigger the scheduled
# monthly programacion cascade endpoint.
CRON_SECRET=

# Comma-separated list of allowed CORS origins (no wildcard).
CORS_ORIGINS=

# Signing key for auth JWTs (login tokens + OAuth state tokens). No insecure
# default — set to a long random value in every real environment.
SECRET_KEY=

# How long an issued login JWT stays valid, in days.
ACCESS_TOKEN_EXPIRE_DAYS=7

# Used to build the Google OAuth2 callback redirect_uri
# (<BASE_URL>/auth/google/callback).
BASE_URL=http://localhost:8000

# Comma-separated allow-list of frontend URLs OAuth is permitted to redirect
# back to after login.
FRONTEND_URLS=

# Google OAuth2 Client ID/Secret (Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth client ID, type "Web application"). Authorized
# redirect URI must be <BASE_URL>/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
